{
  "name": "Algotrade.io",
  "private": true,
  "version": "1.0.0",
  "description": "Vite app for Algotrade.io",
  "type": "module",
  "scripts": {
    "dev": "VITE_APP_DOMAIN=\"$(basename ${PWD})\" pnpm run start",
    "lint": "eslint . --ext .ts,.tsx --max-warnings 0 -c src/ui/config/eslint.config.json",
    "typescript": "tsc -p src/ui/config/tsconfig.json --noEmit",
    "build": "pnpm run swagger && pnpm run typescript && NODE_OPTIONS=--max-old-space-size=8192 vite build -c src/ui/config/vite.config.ts",
    "preview": "vite preview -c src/ui/config/vite.config.ts",
    "start": "vite -c src/ui/config/vite.config.ts",
    "ci": "rm -rf node_modules && pnpm install --frozen-lockfile",
    "amp": "APP_ID=\"${APP_ID}\" ENV=\"${ENV}\" amplify/pull.sh",
    "clean": "rm -rf node_modules && rm -rf src/.umi",
    "swagger": "redocly bundle src/api/spec/swagger.yaml -o src/ui/gen/swagger.json",
    "visualize": "vite-bundle-visualizer -c src/ui/config/vite.config.ts -t treemap --open -o ${PWD}/stats.html",
    "test:open": "dotenv -e config.env -- npx cypress open --config-file src/ui/config/cypress.config.ts",
    "test": "dotenv -e config.env -- npx cypress run --config-file src/ui/config/cypress.config.ts",
    "test:vrt": "dotenv -e config.env -- npx cypress run --config-file src/ui/config/cypress.config.ts --spec cypress/e2e/VRT.spec.cy.ts",
    "test:vrt:accept": "for f in cypress/vrt/diff/*.png; do cp \"cypress/vrt/comparison/$(basename $f)\" \"cypress/vrt/baseline/$(basename $f)\"; done && rm -rf cypress/vrt/diff cypress/vrt/comparison",
    "test:vrt:update": "rm -rf cypress/vrt/baseline cypress/vrt/comparison cypress/vrt/diff && pnpm run test:vrt"
  },
  "author": "Krish Suchak",
  "license": "MIT",
  "dependencies": {
    "@ant-design/icons": "^5.0.0",
    "@aws-amplify/ui-react": "^4.3.1",
    "antd": "^6.0.0",
    "aws-amplify": "^5.0.7",
    "plotly.js-dist-min": "^2.20.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-plotly.js": "^2.6.0",
    "react-router-dom": "^6.6.1",
    "react-syntax-highlighter": "^15.5.0",
    "react-use-websocket": "^4.5.0",
    "swagger-ui-react": "^5.0.0"
  },
  "devDependencies": {
    "@cypress/code-coverage": "^3.10.7",
    "@redocly/cli": "^2.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "@vitejs/plugin-react": "^4.0.0",
    "cypress": "^15.0.0",
    "cypress-image-diff-js": "^2.5.0",
    "cypress-vite": "^1.4.0",
    "eslint": "^8.57.0",
    "eslint-plugin-cypress": "^2.15.1",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-react": "^7.34.1",
    "eslint-plugin-react-hooks": "^4.6.0",
    "less": "^4.1.3",
    "nyc": "^18.0.0",
    "typescript": "^5.0.0",
    "vite": "^4.3.9",
    "vite-plugin-istanbul": "^4.1.0"
  }
}